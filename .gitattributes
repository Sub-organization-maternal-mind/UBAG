# Shell scripts and container entrypoints must use LF so they run under
# /bin/sh inside Linux containers. CRLF causes "sh: bad interpreter" /
# parse failures (e.g. the live-browser browser-viewer entrypoint).
*.sh text eol=lf
deploy/**/entrypoint.sh text eol=lf

# Normalize all code to LF (server edits were introducing CRLF churn)
* text=auto eol=lf
*.go text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.mjs text eol=lf
