{
  "name": "@ubag/security",
  "version": "0.0.0",
  "private": true,
  "description": "Security and compliance contract scaffolding for UBAG auth, authz, audit, and webhook signing.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "validate": "pnpm run build && node scripts/validate-security-contracts.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^7.0.2"
  }
}
