{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ubag.dev/schemas/registry-index.v1.json",
  "title": "UBAG Adapter Registry Index",
  "description": "Extended registry index. Supersets adapters/registry.json with per-adapter versioning, capability flags, drift-detection metadata, and signing/verification fields (manifest checksums).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "adapters"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ubag.adapters.index.v1"
    },
    "kind": { "type": "string" },
    "description": { "type": "string" },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp of index generation."
    },
    "safe_mode": {
      "type": "object",
      "additionalProperties": true
    },
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "manifest",
          "version",
          "status",
          "capabilities",
          "supported_command_types",
          "drift",
          "checksum"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
          "manifest": {
            "type": "string",
            "description": "Relative path to the adapter manifest, as in registry.json."
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+].+)?$"
          },
          "status": {
            "type": "string",
            "enum": ["mock", "stub", "experimental", "beta", "stable", "deprecated"]
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supported_command_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "drift": {
            "type": "object",
            "additionalProperties": false,
            "required": ["baseline_required", "selector_strategy_type"],
            "properties": {
              "baseline_required": {
                "type": "boolean",
                "description": "Whether the adapter requires a DOM selector drift baseline."
              },
              "selector_strategy_type": { "type": "string" }
            }
          },
          "checksum": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$",
            "description": "SHA-256 of the raw manifest file bytes. Used for tamper detection and drift checks."
          },
          "model_catalog": {
            "type": "object",
            "additionalProperties": false,
            "required": ["settings"],
            "description": "Caller-selectable provider UI settings surfaced from the adapter manifest, keyed by the adapter's own setting keys. Absent when the adapter declares none.",
            "properties": {
              "settings": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind"],
                  "properties": {
                    "kind": { "type": "string", "enum": ["choice", "toggle"] },
                    "values": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "signature": {
            "type": "string",
            "description": "Optional detached signature over the checksum (publisher key). Verification is out of scope for v1 but the field is reserved."
          }
        }
      }
    }
  }
}
