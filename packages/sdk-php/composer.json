{
  "name": "ubag/sdk",
  "description": "PHP client for the UBAG v0 REST gateway with stable errors and idempotency.",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Ubag\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ubag\\Sdk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
