{
  "suite": "ubag.v0.sdk.baseline",
  "api_version": "2026-05-22",
  "description": "Executable JSON scenarios for TypeScript, Python, and Go SDK conformance runners.",
  "coverage_scenarios": [
    {
      "id": "retries.retryable-error",
      "category": "retries",
      "title": "Retry policy keeps the same idempotency key for retryable gateway failures",
      "assertions": ["same_idempotency_key", "bounded_attempts", "jittered_backoff"]
    },
    {
      "id": "streaming.sse-ordered-events",
      "category": "streaming",
      "title": "SSE helpers preserve per-job event ordering",
      "assertions": ["ordered_sequence", "terminal_event_required", "bounded_reader"]
    },
    {
      "id": "timeouts.client-abort",
      "category": "timeouts",
      "title": "Client timeout aborts without changing idempotency state",
      "assertions": ["caller_timeout", "transport_abort", "retryable_transport_error"]
    },
    {
      "id": "unicode.prompt-roundtrip",
      "category": "unicode",
      "title": "Unicode prompts round-trip through request serialization",
      "assertions": ["utf8_request_body", "no_mojibake", "stable_content_length"]
    },
    {
      "id": "large-payload.request-limit",
      "category": "large_payloads",
      "title": "Large request bodies surface stable validation errors",
      "assertions": ["body_limit_error", "trace_id_preserved", "no_partial_retry"]
    },
    {
      "id": "malformed-response.error-surface",
      "category": "malformed_responses",
      "title": "Malformed gateway responses surface transport errors with raw body access",
      "assertions": ["raw_body_preserved", "typed_transport_error", "no_secret_logging"]
    },
    {
      "id": "webhooks.signature-helpers",
      "category": "webhooks",
      "title": "Webhook helper signs timestamp.nonce.body and rejects replay",
      "assertions": ["hmac_base_string", "timestamp_tolerance", "nonce_replay_rejection"]
    },
    {
      "id": "sidecar.discovery-loopback",
      "category": "sidecar",
      "title": "Sidecar discovery prefers loopback and rejects public binding by default",
      "assertions": ["loopback_default", "health_probe", "gateway_proxy"]
    },
    {
      "id": "executor.gateway-dispatch",
      "category": "executor",
      "title": "Gateway dispatches accepted work once after payload policy and idempotency checks",
      "assertions": ["payload_policy_before_enqueue", "single_enqueue_per_idempotency_key", "queue_metrics_exposed"]
    },
    {
      "id": "worker.file-spool-result-ingestion",
      "category": "worker",
      "title": "File-spool worker consumer leases gateway work and ingests normalized terminal results",
      "assertions": ["atomic_file_lease", "worker_jsonl_event_ingestion", "terminal_result_persisted", "cancelled_jobs_not_revived"]
    },
    {
      "id": "worker.nats-result-ingestion",
      "category": "worker",
      "title": "NATS worker consumer leases JetStream jobs and ingests normalized terminal results",
      "assertions": ["durable_pull_consumer", "cancel_subjects_not_executed", "ack_after_terminal_ingestion", "poison_mismatched_envelopes"]
    },
    {
      "id": "webhooks.outbox-retry-worker",
      "category": "webhooks",
      "title": "Webhook outbox persists terminal job callbacks and retries signed delivery attempts",
      "assertions": ["durable_outbox_delivery", "hmac_signed_http_post", "bounded_retry_backoff", "replay_requires_existing_delivery"]
    }
  ],
  "scenarios": [
