{
  "schema_version": "ubag.adapter.v0",
  "id": "chatgpt_web",
  "display_name": "ChatGPT Web",
  "version": "0.1.0",
  "status": "stub",
  "adapter_path": "chatgpt_web",
  "entrypoint": "ubag_chatgpt_web_adapter:ChatGptWebAdapter",
  "target_homepage": "https://chatgpt.com/",
  "aliases": [
    "chatgpt",
    "chatgpt-web",
    "openai_chatgpt"
  ],
  "login_posture": "manual_required",
  "supported_command_types": [
    "chat.prompt",
    "chat.stream",
    "conversation.resume"
  ],
  "capabilities": [
    "prompt_run",
    "token_streaming",
    "conversation_resume",
    "drift_baseline_required",
    "file_attach"
  ],
  "model_catalog": {
    "settings": {
      "model": {
        "kind": "choice",
        "values": ["GPT-5.6 Sol", "GPT-5.5", "GPT-5.4", "GPT-5.3", "o3"]
      },
      "thinking": {
        "kind": "choice",
        "values": ["Instant", "Medium", "High"]
      }
    }
  },
  "attachments": {
    "max_files": 10,
    "max_file_bytes": 33554432,
    "accepted": [
      { "kind": "document", "content_types": ["application/pdf", "text/plain", "text/markdown", "text/csv", "application/json"] },
      { "kind": "image", "content_types": ["image/png", "image/jpeg", "image/gif", "image/webp"] },
      { "kind": "audio", "content_types": ["audio/webm", "audio/wav", "audio/x-wav", "audio/mpeg", "audio/mp4", "audio/ogg"] },
      { "kind": "voice", "content_types": ["audio/webm", "audio/wav", "audio/x-wav", "audio/mpeg", "audio/mp4", "audio/ogg"] },
      { "kind": "video", "content_types": ["video/mp4", "video/webm"] }
    ]
  },
  "selector_strategy": {
    "type": "provider_specific",
    "drift_baseline_required": true
  },
  "artifact_policy": {
    "screenshots": "on_failure_only",
    "dom_snapshots": "drift_baseline_only",
    "recordings": "post_login_debug_only"
  },
  "safe_mode": {
    "manual_login_required": true,
    "user_owned_sessions_only": true,
    "automated_login": "forbidden",
    "credential_scraping": "forbidden",
    "credential_storage": "forbidden",
    "captcha_solving": "forbidden",
    "captcha_bypass": "forbidden"
  },
  "credential_policy": {
    "collect_credentials": false,
    "read_credentials_from_payload": false,
    "scrape_credentials": false,
    "store_credentials": false
  },
  "captcha_policy": {
    "solve": false,
    "bypass": false,
    "delegate_to_solver": false,
    "manual_only": true
  },
  "synthetic_test_prompts": [
    "Reply with the word ready."
  ],
  "resource_policy": {
    "network": "blocked_until_manual_session_runtime",
    "browser": "manual_user_owned_session_required"
  },
  "not_implemented_reason": "ChatGPT Web ships real Playwright manual-session automation behind the worker's live engine (run_live). The default registry dispatch stays fail-closed: it requires a user-owned manual browser session runtime, manual login, and a re-confirmed drift baseline before executing jobs."
}
