{
  auto_https off
  admin localhost:2019
}

:80 {
  encode zstd gzip

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    X-Frame-Options "DENY"
  }

  handle /healthz {
    respond "ok" 200
  }

  handle /v1/metrics* {
    respond "not found" 404
  }

  handle /v1/ready* {
    respond "not found" 404
  }

  handle /v1/* {
    reverse_proxy gateway:8080
  }

  # Live-browser viewer (noVNC). Only resolves when the "live-browser" compose
  # profile is running; otherwise Caddy returns 502. The remote display is still
  # password-gated by the browser-viewer service (UBAG_BROWSER_VNC_PASSWORD).
  handle /novnc/* {
    # Allow the same-origin dashboard to embed the viewer in an iframe while the
    # global default keeps every other surface at X-Frame-Options: DENY.
    header X-Frame-Options "SAMEORIGIN"
    uri strip_prefix /novnc
    reverse_proxy browser-viewer:6080
  }

  # SvelteKit dashboard — served at /dashboard/ with SPA fallback.
  # All SvelteKit static assets (_app/, favicon, sw.js, manifest) are also served
  # from the dashboard dist so absolute-path asset URLs resolve correctly when
  # Nginx Proxy Manager forwards the whole domain to this Caddy instance.
  handle /dashboard/* {
    uri strip_prefix /dashboard
    root * /srv/dashboard
    try_files {path} /index.html
    file_server
  }

  # SvelteKit hashed JS/CSS bundles — absolute paths baked into index.html.
  handle /_app/* {
    root * /srv/dashboard
    file_server
  }

  # PWA + favicon static assets
  handle /favicon.svg {
    root * /srv/dashboard
    file_server
  }

  handle /manifest.webmanifest {
    root * /srv/dashboard
    file_server
  }

  handle /sw.js {
    root * /srv/dashboard
    file_server
  }

  handle / {
    redir /dashboard/ permanent
  }

  respond "UBAG small ingress is running. API routes are available under /v1/*. Dashboard at /dashboard/." 200
}
