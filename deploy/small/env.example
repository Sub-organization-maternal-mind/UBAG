# Copy this file to deploy/small/env.local for local runs.
# Values below are placeholders only. Replace them before any shared deployment.

UBAG_EDGE_BIND_HOST=127.0.0.1
UBAG_BACKING_BIND_HOST=127.0.0.1
UBAG_ALLOW_PUBLIC_BACKING_PORTS=false

UBAG_APP_SECRET=replace-with-local-app-secret
UBAG_API_VERSION=2026-05-22
UBAG_GATEWAY_VERSION=0.0.0-small
UBAG_BUILD_COMMIT=local
# RBAC role bound to the app-secret bearer token (the "user type").
# One of: viewer | service | developer | operator | admin | superadmin.
# Empty defaults to "service". This is machine auth — there are no user
# email/password accounts; the token IS the credential.
UBAG_ACTOR_ROLE=
UBAG_GATEWAY_PORT=8080
UBAG_CADDY_HTTP_PORT=8081
UBAG_CADDY_HTTPS_PORT=8443
UBAG_CADDYFILE=./deploy/small/caddy/Caddyfile
# UBAG_CADDYFILE=./deploy/caddy/Caddyfile.standard  # use hardened config (requires xcaddy build with rate-limit + WAF modules)
UBAG_PUBLIC_DOMAIN=ubag.example.com
UBAG_GATEWAY_STORE=memory
UBAG_POSTGRES_DSN=postgres://ubag:replace-with-local-postgres-password@postgres:5432/ubag?sslmode=disable
UBAG_IDEMPOTENCY_TTL_HOURS=24
UBAG_DATABASE_MAX_OPEN_CONNS=10
UBAG_DATABASE_MAX_IDLE_CONNS=5
UBAG_DATABASE_CONN_MAX_LIFETIME_SECONDS=300
UBAG_EXECUTOR_MODE=noop
UBAG_EXECUTOR_SPOOL_DIR=/var/lib/ubag/executor-spool
UBAG_NATS_URL=nats://nats:4222
UBAG_NATS_STREAM=UBAG_JOBS
UBAG_NATS_SUBJECT=ubag.jobs
UBAG_NATS_WORKER_DURABLE=ubag-worker
UBAG_NATS_WORKER_ACK_WAIT_MS=35000
UBAG_NATS_WORKER_NAK_DELAY_MS=1000
UBAG_NATS_WORKER_FETCH_WAIT_MS=500
UBAG_NATS_WORKER_MAX_DELIVER=5
UBAG_ARTIFACT_STORE=memory
UBAG_MINIO_ENDPOINT=minio:9000
UBAG_MINIO_ACCESS_KEY=ubag-gateway
UBAG_MINIO_SECRET_KEY=replace-with-local-minio-gateway-password
UBAG_MINIO_BUCKET=ubag-artifacts
UBAG_MINIO_USE_SSL=false
UBAG_WORKER_CONSUMER_ENABLED=false
UBAG_WORKER_PYTHON=/usr/bin/python3
UBAG_WORKER_SCRIPT=/app/apps/worker/run_mock_worker.py
UBAG_WORKER_POLL_INTERVAL_MS=500
UBAG_WORKER_MAX_RUNTIME_MS=30000

# --- Live-browser viewer (noVNC) — opt-in, ToS-safe manual login ------------
# Enable with the "live-browser" compose profile:
#   docker compose -f docker-compose.small.yml --profile live-browser up -d
# A real persistent Chromium runs on the worker host and is streamed to the
# operator over noVNC for MANUAL login/CAPTCHA/2FA. UBAG never captures
# credentials, cookies, or storage state, and never solves challenges.
# REQUIRED when the profile is enabled — the remote display is password-gated:
UBAG_BROWSER_VNC_PASSWORD=replace-with-local-vnc-password
# Loopback noVNC port published on the host (must match UBAG_NOVNC_BASE_URL).
UBAG_NOVNC_PORT=7900
# Loopback base advertised in session.manual_action_required events. Keep it
# loopback — the gateway only forwards loopback noVNC URLs to operators.
UBAG_NOVNC_BASE_URL=http://127.0.0.1:7900
# Point the worker at the shared Chromium (CDP) so live jobs reuse the
# user-owned, manually-logged-in profile. Leave empty to disable the bridge.
UBAG_REMOTE_BROWSER_ENDPOINT=http://browser-viewer:9222
UBAG_BROWSER_HEADED=false
UBAG_BROWSER_ENGINE=chromium
UBAG_BROWSER_PROTOCOL=cdp

UBAG_WEBHOOK_OUTBOX=memory
UBAG_WEBHOOK_WORKER_ENABLED=false
UBAG_WEBHOOK_SECRET=replace-with-local-webhook-secret
UBAG_WEBHOOK_SECRET_ENV_PREFIX=UBAG_WEBHOOK_SECRET_
UBAG_WEBHOOK_MAX_ATTEMPTS=8
UBAG_WEBHOOK_POLL_INTERVAL_MS=1000
UBAG_WEBHOOK_BATCH_SIZE=10
UBAG_WEBHOOK_LEASE_MS=30000
UBAG_WEBHOOK_REQUEST_TIMEOUT_MS=10000
UBAG_WEBHOOK_RETRY_BASE_MS=1000
UBAG_WEBHOOK_RETRY_MAX_MS=300000
UBAG_WEBHOOK_MAX_RESPONSE_BYTES=8192
UBAG_WEBHOOK_WORKER_ID=gateway-webhook-worker
UBAG_WEBHOOK_ALLOW_INSECURE_HTTP=false
UBAG_WEBHOOK_ALLOW_PRIVATE_HOSTS=false
UBAG_WEBHOOK_ALLOWED_HOSTS=
UBAG_WEBHOOK_ALLOW_ANY_PUBLIC_HOST=false

POSTGRES_DB=ubag
POSTGRES_USER=ubag
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_PORT=5432

DRAGONFLY_PORT=6379

MINIO_ROOT_USER=ubag-root
MINIO_ROOT_PASSWORD=replace-with-local-minio-root-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://127.0.0.1:9001

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=set-a-local-grafana-admin-password

NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
