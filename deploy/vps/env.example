# Copy to deploy/vps/env.local on the VPS and fill in real values there.
# env.local is gitignored — never commit real secrets.

UBAG_APP_SECRET=replace-with-a-strong-random-secret
UBAG_API_VERSION=2026-05-22
UBAG_GATEWAY_VERSION=0.0.0-vps
UBAG_BUILD_COMMIT=local
# RBAC role bound to the app-secret bearer token. One of:
# viewer | service | developer | operator | admin | superadmin.
# Empty defaults to "service" (denies Browser Sessions/Webhooks/etc via 403).
UBAG_ACTOR_ROLE=superadmin

POSTGRES_DB=ubag
POSTGRES_USER=ubag
POSTGRES_PASSWORD=replace-with-a-strong-random-password

# Optional overrides (sane defaults already set in docker-compose.vps.yml):
# UBAG_IDEMPOTENCY_TTL_HOURS=24
# UBAG_DATABASE_MAX_OPEN_CONNS=5
# UBAG_DATABASE_MAX_IDLE_CONNS=2
# UBAG_DATABASE_CONN_MAX_LIFETIME_SECONDS=300
# UBAG_WORKER_POLL_INTERVAL_MS=500
# UBAG_WORKER_MAX_RUNTIME_MS=120000
# UBAG_WEBHOOK_SECRET=
