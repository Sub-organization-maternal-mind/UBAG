# UBAG gateway environment file (template).
# Copy to a protected location (root-owned, chmod 0600) before use.
# Replace every placeholder. Mirrors deploy/small/env.example (UBAG_* subset).

UBAG_GATEWAY_ADDR=:8080
UBAG_API_VERSION=2026-05-22
UBAG_GATEWAY_VERSION=0.0.0-small
UBAG_BUILD_COMMIT=local

# Secret: REQUIRED. Generate a strong random value.
UBAG_APP_SECRET=replace-with-strong-app-secret

# Store selection. Use postgres for durable state.
UBAG_GATEWAY_STORE=memory
# UBAG_POSTGRES_DSN=postgres://ubag:replace-me@127.0.0.1:5432/ubag?sslmode=require

UBAG_EXECUTOR_MODE=noop
UBAG_EXECUTOR_SPOOL_DIR=/var/lib/ubag/executor-spool

UBAG_ARTIFACT_STORE=memory
UBAG_WEBHOOK_OUTBOX=memory
UBAG_WEBHOOK_WORKER_ENABLED=false
UBAG_WEBHOOK_ALLOW_INSECURE_HTTP=false
UBAG_WEBHOOK_ALLOW_PRIVATE_HOSTS=false
UBAG_WEBHOOK_ALLOW_ANY_PUBLIC_HOST=false
