{
  "title": "UBAG Webhook Delivery",
  "uid": "ubag-webhook-delivery",
  "schemaVersion": 36,
  "version": 1,
  "tags": [
    "ubag",
    "webhooks"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Delivery Attempts/s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(ubag_webhook_deliveries_total[1m])",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Delivery Latency (avg s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(ubag_webhook_delivery_duration_seconds_sum[5m])/rate(ubag_webhook_delivery_duration_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbox Depth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "ubag_webhook_outbox_depth",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox Oldest Age (s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "ubag_webhook_outbox_oldest_age_seconds",
          "legendFormat": "{{state}}"
        }
      ]
    }
  ]
}