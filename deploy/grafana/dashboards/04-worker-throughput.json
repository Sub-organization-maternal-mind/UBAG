{
  "title": "UBAG Worker Throughput",
  "uid": "ubag-worker-throughput",
  "schemaVersion": 36,
  "version": 1,
  "tags": [
    "ubag",
    "worker"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Worker Jobs Processed/s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(ubag_worker_jobs_processed_total[1m])",
          "legendFormat": "{{worker_pool}} {{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Worker Duration (avg s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(ubag_worker_job_duration_seconds_sum[5m])/rate(ubag_worker_job_duration_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Result Ingestion Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(ubag_worker_result_ingestions_total[1m])",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Artifact Captures/s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(ubag_artifact_captures_total[1m])",
          "legendFormat": "{{artifact_type}}"
        }
      ]
    }
  ]
}