{
  "title": "UBAG Queue Depth",
  "uid": "ubag-queue-depth",
  "schemaVersion": 36,
  "version": 1,
  "tags": [
    "ubag",
    "queue"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queue Depth by State",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "ubag_queue_depth",
          "legendFormat": "{{queue}} {{state}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Oldest Job Age (s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "ubag_queue_oldest_job_age_seconds",
          "legendFormat": "{{queue}} {{state}}"
        }
      ]
    }
  ]
}